# Google Ads — rastreamento de conversões (gtag.js)
#
# NOTA: este site é HTML estático servido pela Vercel SEM etapa de build,
# portanto NÃO há injeção de env var no browser (prefixos VITE_/NEXT_PUBLIC_
# só funcionam com bundler). A fonte de verdade em runtime é o arquivo
# versionado `assets/analytics.js`. Estes valores são públicos por natureza
# (aparecem no gtag visível na página) e ficam aqui apenas como DOCUMENTAÇÃO
# de referência para configuração no Google Ads.

# ID da conta do Google Ads (gtag)
GOOGLE_ADS_ID="AW-18323827538"

# Label da conversão de clique no WhatsApp
CONV_WHATSAPP="dH_BCKTk1dEcENLWvaFE"

